# Reproducibilidad
# Misma seed => mismo dataset sintético (ideal para demo).
AURA_SEED=42

# Tamaño del dataset (para demo rápida o prueba más grande)
AURA_N_ASEGURADOS=1000
AURA_N_PROVEEDORES=50

# Tasa de fraude simulada (alineado a "etiqueta_fraude_simulada")
AURA_FRAUD_RATE=0.15

# Señal PDF: borde de vigencia y reporte tardío
AURA_FRAUD_NEAR_START_PROB=0.30
AURA_NEAR_START_DAYS_MAX=40
AURA_NORMAL_DAYS_SINCE_START_MIN=10
AURA_NORMAL_DAYS_SINCE_START_MAX=200

AURA_FRAUD_LATE_REPORT_PROB=0.50
AURA_LATE_REPORT_DAYS_MIN=3
AURA_LATE_REPORT_DAYS_MAX=12
AURA_NORMAL_REPORT_DAYS_MIN=1
AURA_NORMAL_REPORT_DAYS_MAX=5

# NLP: probabilidad de clon/paráfrasis en fraude (para detectar narrativas similares sin saturar)
AURA_NARRATIVE_CLONE_PROB=0.10

# Documentos completos: probabilidad de que el caso tenga documentación completa
AURA_DOCS_COMPLETE_PROB_FRAUD_ROBO=0.70
AURA_DOCS_COMPLETE_PROB_NORMAL_ROBO=0.80
AURA_DOCS_COMPLETE_PROB_FRAUD_NO_ROBO=0.80
AURA_DOCS_COMPLETE_PROB_NORMAL_NO_ROBO=0.90

# Historial de siniestros: controles macro para realismo
AURA_FRAUD_HIGH_HISTORY_PROB=0.80
AURA_HISTORY_FRAUD_MIN=2
AURA_HISTORY_FRAUD_MAX=5
AURA_HISTORY_NORMAL_MIN=0
AURA_HISTORY_NORMAL_MAX=2

# Distribución de coberturas (debe sumar ~1.0; se normaliza por `random.choices`)
AURA_COVERAGE_WEIGHT_CHOQUE=0.34
AURA_COVERAGE_WEIGHT_ROBO=0.33
AURA_COVERAGE_WEIGHT_DANOS=0.33

# Documentos: probabilidad de inconsistencia/adulteración por documento (señal PDF)
AURA_DOC_SUSPICIOUS_PROB=0.05

# Documentos: cantidad por siniestro (adjuntos)
AURA_DOCS_PER_CLAIM_MIN=1
AURA_DOCS_PER_CLAIM_MAX=3

# Monto estimado vs monto reclamado (ruido de estimación)
AURA_MONTO_ESTIMADO_FACTOR_MIN=0.85
AURA_MONTO_ESTIMADO_FACTOR_MAX=1.10

# Parámetros "macro" para realismo controlado (proveedores / lista restrictiva)
# % de proveedores que caen en el grupo "semi-sospechoso"
AURA_SUSPECT_PROVIDER_RATE=0.08
# límites del tamaño del grupo (para no hacer el patrón ni muy obvio ni inexistente)
AURA_SUSPECT_PROVIDER_MIN=2
AURA_SUSPECT_PROVIDER_MAX=8

# Probabilidades de caer en el grupo sospechoso
# Fraude: probabilidad de usar proveedor del grupo sospechoso
AURA_FRAUD_TO_SUSPECT_PROB=0.25
# No fraude: ruido (algunos casos normales también van a esos proveedores)
AURA_NORMAL_TO_SUSPECT_PROB=0.15

